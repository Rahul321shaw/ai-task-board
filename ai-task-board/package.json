{
  "name": "ai-task-board",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "db:push": "pnpm --filter @ai-task-board/api db:push",
    "db:migrate": "pnpm --filter @ai-task-board/api db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": ["apps/*", "packages/*"],
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  }
}